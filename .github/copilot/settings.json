{
  // Repository-level Copilot CLI settings (committed, shared).
  // Routes the review/critique loop's reviewer subagent to a model/effort/context
  // distinct from the author session, so cross-model coverage is baked in.
  // Cascade: ~/.copilot/settings.json (user) -> this file (repo) -> .github/copilot/settings.local.json (local).
  // NOTE: only `model`, `effortLevel`, `contextTier` are settable per subagent; rotate `model`
  // across rounds (gpt-5.5 / claude-opus-4.8 / gemini-3.1-pro-preview) for vendor diversity.
  // `xhigh` is invalid for Gemini (caps at `high`) — drop effort if you rotate to a Gemini model.
  "subagents": {
    "agents": {
      "synopsis-reviewer": {
        "model": "gpt-5.5",
        "effortLevel": "xhigh",
        "contextTier": "long_context"
      }
    }
  }
}
